---
// Sticky FAQ
// ------------
// Description: A sticky FAQ section with a title and a subtitle
// Properties:
// - title: The title of the hero section
// - text: The subtitle of the hero section
// - classes: Additional classes to be added to the hero section

// Components
// - Layout
import SectionSticky from '../../blocks/basic/StickySidebar.astro'
// - UI
import Header from '../../ui/Header.astro'
import DecorationBorder from '../../ui/DecorationBorder.astro'

// Content
// - Props
type Props = {
	title?: string
	subtitle?: string
	classes?: string
}
const { title = '', subtitle = '', classes = '' } = Astro.props
---

<SectionSticky classes={`${classes ? classes : ''}`}>
	<Header
		title={title}
		subtitle={subtitle}
		headingLevel="h2"
		titleClasses="bg-white dark:bg-neutral-950 "
		slot="sidebar"
	/>

	<div class="faq">
		<div class="faq__item">
			<h3 class="faq__item__title">How long does it take to build a website?</h3>
			<p class="faq__item__text">
				Timelines depend on the size and complexity of the project. A straightforward 5-page
				website typically takes 3–4 weeks from approved design to launch. Larger sites with CMS
				integration or custom features usually take 6–10 weeks. We’ll give you a clear timeline
				in your project proposal before work begins.
			</p>
			<DecorationBorder type="top bottom" style="dashed" />
		</div>
		<div class="faq__item">
			<h3 class="faq__item__title">What do you need from me to get started?</h3>
			<p class="faq__item__text">
				To kick things off, we’ll need a brief overview of your business, your goals for the
				website, and any brand assets you have (logo, colours, fonts). Don’t worry if you don’t
				have everything ready — we can help you figure out what you need during the discovery call.
			</p>
			<DecorationBorder type="top bottom" style="dashed" />
		</div>
		<div class="faq__item">
			<h3 class="faq__item__title">Will I be able to update the website myself?</h3>
			<p class="faq__item__text">
				Yes. We integrate a content management system (CMS) into every site that needs one, so you
				can update text, images, blog posts, and more without any technical knowledge. We also
				provide a walkthrough and documentation so you feel confident managing your site from day one.
			</p>
			<DecorationBorder type="top bottom" style="dashed" />
		</div>
		<div class="faq__item">
			<h3 class="faq__item__title">Do you offer ongoing maintenance and support?</h3>
			<p class="faq__item__text">
				Yes. All projects include 30 days of post-launch support at no extra cost. After that,
				we offer flexible monthly maintenance plans that cover software updates, security
				monitoring, backups, and priority support — so your website stays fast, secure, and up
				to date.
			</p>
			<DecorationBorder type="top bottom" style="dashed" />
		</div>
		<div class="faq__item">
			<h3 class="faq__item__title">Can you redesign an existing website?</h3>
			<p class="faq__item__text">
				Absolutely. Redesigns are one of our most common projects. We’ll start with an audit of
				your current site to understand what’s working and what isn’t, then design and build
				something that looks better, performs better, and serves your business better.
			</p>
			<DecorationBorder type="top bottom" style="dashed" />
		</div>
	</div>
</SectionSticky>

<style>
	@reference '../../../styles/global.css';
	.faq {
		@apply flex flex-col gap-6 lg:gap-8;
	}
	.faq__item {
		@apply relative bg-white p-6 lg:p-8 dark:bg-neutral-950;
	}
	.faq__item__title {
		@apply mb-2 text-2xl leading-8;
	}
	.faq__item__text {
		@apply mb-0 text-xl leading-8;
	}
</style>
