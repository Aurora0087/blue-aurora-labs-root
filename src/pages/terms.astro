---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
import Row from '../components/ui/Row.astro'
import Col from '../components/ui/Col.astro'
// - Blocks
import Hero from '../components/blocks/hero/SimpleHeroNeutral.astro'
import SectionSticky from '../components/blocks/basic/StickySidebarTransparent.astro'
// - UI
import Header from '../components/ui/Header.astro'

// Content
// - SEO
const SEO = {
	title: 'Blue Aurora Labs | Terms & Conditions',
	description:
		'Review the terms and conditions for working with Blue Aurora Labs, including project agreements, payment terms, and usage rights for delivered work.'
}
// - Hero
const heroData = {
	title: 'Clear and Fair Terms for Working Together',
	subtitle: 'Terms & Conditions',
	text: 'These Terms and Conditions explain how we work, what you can expect from us, and what we need from you. We\'ve kept them straightforward so there are no surprises.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero
		title={heroData.title}
		subtitle={heroData.subtitle}
		text={heroData.text}
		textClasses="max-w-xl!"
	/>
	<SectionSticky>
		<Header
			title="About This Agreement"
			subtitle="Introduction"
			headingLevel="h2"
			titleClasses="bg-white dark:bg-neutral-950"
			slot="sidebar"
		/>
		<Row decorationBorder="top bottom" decorationBorderStyle="dashed" style="transparent">
			<Col span="12" style="transparent">
				<div class="text-basic bg-white p-8 dark:bg-neutral-950 [&_h3]:text-xl!">
					<h3>Welcome to Blue Aurora Labs</h3>
					<p>
						Thank you for choosing Blue Aurora Labs. We are a web design and development agency
						dedicated to building high-quality websites that help businesses grow online. These
						Terms and Conditions govern the agreement between Blue Aurora Labs and you, our client,
						regarding the services we provide.
					</p>
					<p>
						By engaging our services or signing a project agreement, you confirm that you have read,
						understood, and agree to these terms. If you have any questions, please reach out to us
						before work begins — we’re happy to clarify anything.
					</p>
					<h3>Acceptance of Terms</h3>
					<p>
						By commissioning a project or engaging Blue Aurora Labs for any service, you agree to be
						bound by these Terms and Conditions. These terms apply to all projects, retainer
						agreements, and ongoing support arrangements we enter into with clients.
					</p>
					<p>
						We may update these terms from time to time to reflect changes in our services or legal
						requirements. Any updates will be communicated to active clients and posted on our
						website. Continued use of our services after an update constitutes acceptance of the
						revised terms.
					</p>
					<h3>Our Commitment to You</h3>
					<p>
						At Blue Aurora Labs, we are committed to delivering websites and digital experiences that
						meet your goals and exceed your expectations. We work collaboratively with every client
						to ensure the final product reflects your brand, resonates with your audience, and
						performs reliably.
					</p>
					<p>
						Your feedback is important throughout every stage of the project. We build in review
						checkpoints so you remain in control. If something isn’t right, we will work with you
						until it is.
					</p>
				</div>
			</Col>
		</Row>
	</SectionSticky>
	<SectionSticky>
		<Header
			title="Registration and Use"
			subtitle="User Accounts"
			headingLevel="h2"
			titleClasses="bg-white dark:bg-neutral-950"
			slot="sidebar"
		/>
		<Row decorationBorder="top bottom" decorationBorderStyle="dashed" style="transparent">
			<Col span="12" style="transparent">
				<div class="text-basic bg-white p-8 dark:bg-neutral-950 [&_h3]:text-xl!">
					<h3>Project Briefs & Agreements</h3>
					<p>
						All projects begin with a written brief or scope of work agreed upon by both parties.
						This document outlines deliverables, timelines, and costs. Work will not begin until
						both parties have confirmed the scope in writing and an initial deposit has been
						received.
					</p>
					<p>
						Any changes to the agreed scope during the project may result in revised timelines or
						additional costs. We will always notify you before proceeding with out-of-scope work and
						provide an updated estimate for your approval.
					</p>
					<h3>Payment Terms</h3>
					<p>
						Projects are invoiced in stages as outlined in the project agreement. Typically this
						involves a deposit before work begins, a mid-project payment at a defined milestone, and
						a final payment upon completion. All invoices are due within 14 days of issue.
					</p>
					<p>
						Ownership of the completed website and all associated deliverables will be transferred
						to you upon receipt of final payment. Blue Aurora Labs retains the right to showcase
						completed work in our portfolio unless otherwise agreed in writing.
					</p>
					<h3>Client Responsibilities</h3>
					<p>
						As our client, you are responsible for providing content, assets, and feedback in a
						timely manner. Delays caused by late client input may affect the project timeline. We
						will always communicate any timeline impacts as soon as they become apparent.
					</p>
					<p>
						You confirm that any content, images, or materials you provide to us are owned by you
						or that you have the appropriate rights to use them. Blue Aurora Labs accepts no
						liability for copyright infringement arising from client-supplied materials.
					</p>
				</div>
			</Col>
		</Row>
	</SectionSticky>
	<SectionSticky>
		<Header
			title="General Restrictions and Liability"
			subtitle="Limitations and Liability"
			headingLevel="h2"
			titleClasses="bg-white dark:bg-neutral-950"
			slot="sidebar"
		/>
		<Row decorationBorder="top bottom" decorationBorderStyle="dashed" style="transparent">
			<Col span="12" style="transparent">
				<div class="text-basic bg-white p-8 dark:bg-neutral-950 [&_h3]:text-xl!">
					<h3>General Limitations</h3>
					<p>
						Blue Aurora Labs delivers work to the agreed specification and takes every step to
						ensure quality and reliability. However, we cannot guarantee that websites will be
						free from all bugs or that third-party services will remain available or unchanged.
						We will address defects discovered within 30 days of launch as part of our standard
						delivery.
					</p>
					<p>
						We are not liable for losses arising from website downtime caused by hosting
						providers, third-party plugins, or factors outside our control. We strongly recommend
						clients maintain regular backups and appropriate hosting arrangements.
					</p>
					<h3>Third-Party Services</h3>
					<p>
						Many websites we build make use of third-party services such as hosting platforms,
						content management systems, payment gateways, and analytics tools. We will always
						recommend services we consider reliable, but we are not responsible for changes in
						their pricing, terms, or availability.
					</p>
					<p>
						Where we set up third-party accounts on your behalf, login credentials will be handed
						over to you upon project completion. You are responsible for maintaining and securing
						those accounts going forward.
					</p>
					<h3>Maximum Liability</h3>
					<p>
						In no event shall Blue Aurora Labs' total liability to you exceed the total amount paid
						by you for the specific project or service in question. This limitation applies
						regardless of the nature of the claim, whether based in contract, negligence, or
						otherwise.
					</p>
					<p>
						Some jurisdictions do not allow limitations on implied warranties or exclusion of
						incidental damages. In such cases, our liability will be limited to the maximum extent
						permitted by applicable law.
					</p>
				</div>
			</Col>
		</Row>
	</SectionSticky>
</Layout>
