---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - Blocks
import Hero from '../components/blocks/hero/SimpleHeroPrimary.astro'
import BasicFeatures from '../components/blocks/features/StickyBasicFeatures.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'

// Content
// - SEO
const SEO = {
	title: 'Blue Aurora Labs | What We Do',
	description:
		'From custom web design and development to SEO and ongoing maintenance — explore the full range of services Blue Aurora Labs offers to grow your online presence.'
}
// - Hero
const heroData = {
	title: 'Everything your website needs to succeed',
	subtitle: 'What We Do',
	text: 'From first concept to launch day and beyond — we cover every piece of the puzzle so you can focus on running your business.'
}
// - CTA
const ctaData = {
	title: 'Ready to get a website that actually works?',
	text: 'Whether you\'re starting from scratch or need a full redesign, Blue Aurora Labs is ready to build something you\'re proud of. Let\'s talk about your project.',
	buttonLink: '/contact',
	buttonText: 'Start your project'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={heroData.title} subtitle={heroData.subtitle} text={heroData.text} />
	<BasicFeatures />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
