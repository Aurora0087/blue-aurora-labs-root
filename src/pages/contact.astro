---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'

// - Blocks
import Hero from '../components/blocks/hero/SimpleHeroBasic.astro'
import ContactInfo from '../components/blocks/contact/ContactInfoCards.astro'
import Brand from '../components/blocks/brand/Marquee.astro'
import Faq from '../components/blocks/faq/StickyFaq.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'

// Content
// - SEO
const SEO = {
	title: "Blue Aurora Labs | Contact Us",
	description:
		'Get in touch with Blue Aurora Labs to discuss your next website project. We\'re here to answer questions, provide quotes, and help bring your vision to life.'
}
// - Hero data
const heroData = {
	title: 'Let\'s talk about your next website',
	subtitle: 'Get in Touch',
	text: 'Whether you have a brief ready or just an idea, we\'d love to hear from you. Reach out and we\'ll get back to you within one business day.',
}
// - Contact data
const contactData = {
	title: 'Reach us for new projects, support, or partnership enquiries.'
}
// - Brand data
const brandData = {
	title: 'Businesses we\'ve worked with'
}
// - FAQ data
const faqData = {
	title: 'Everything you need to know',
	subtitle: 'Frequently Asked Questions'
}
// - CTA data
const ctaData = {
	title: 'Ready to get a website that actually works?',
	text: "Whether you're starting from scratch or need a full redesign, Blue Aurora Labs is ready to build something you\'re proud of. Let\'s talk about your project.",
	buttonLink: "/contact",
	buttonText: "Start your project"
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero
		title={heroData.title}
		subtitle={heroData.subtitle}
		text={heroData.text}
	/>
	<ContactInfo title={contactData.title} />
	<Brand title={brandData.title} />
	<Faq subtitle={faqData.subtitle} title={faqData.title} />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
