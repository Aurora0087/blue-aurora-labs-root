---
// Home Page
// ------------
// Description: The home page is a page that displays the most important information.

// Components
// - Layout
import Layout from '../layouts/Layout.astro'

// - Blocks
import Hero from '../components/blocks/hero/CenteredHeroCTA.astro'
import Brand from '../components/blocks/brand/Marquee.astro'
import Features from '../components/blocks/features/MasonryGrid.astro'
import ScrollSpySteps from '../components/blocks/onboarding/Steps.astro'
import TestimonialMasonry from '../components/blocks/testimonials/TestimonialMasonry.astro'
import Faq from '../components/blocks/faq/StickyFaq.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'

// Content
// - SEO
const SEO = {
	title:
		'Blue Aurora Labs | Custom Website Design & Development Agency',
	description:
		'Blue Aurora Labs builds high-performance, beautifully crafted websites for businesses of all sizes. From landing pages to full custom builds — we turn your vision into a website that works.'
}
// - Hero data
const heroData = {
	title: 'Websites that work as hard as you do',
	subtitle: 'Built by Blue Aurora Labs',
	buttonLink: '/contact',
	buttonText: 'Start your project',
	text: 'We design and develop high-performance websites tailored to your brand, goals, and audience — from sharp landing pages to fully custom builds.'
}
// - Brand data
const brandData = {
	title: 'Trusted by businesses we\'ve built for'
}
// - Testimonial data
const testimonialData = {
	title: 'Clients who trust us with their online presence',
	subtitle: 'What they\'re saying'
}
// - FAQ data
const faqData = {
	title: 'Frequently Asked Questions',
	subtitle: 'Everything you need to know'
}
// - CTA data
const ctaData = {
	title: 'Ready to get a website that actually works?',
	text: 'Whether you\'re starting from scratch or need a full redesign, Blue Aurora Labs is ready to build something you\'re proud of. Let\'s talk about your project.',
	buttonLink: '/contact',
	buttonText: 'Start your project'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero
		title={heroData.title}
		subtitle={heroData.subtitle}
		buttonLink={heroData.buttonLink}
		buttonText={heroData.buttonText}
	/>
	<Brand title={brandData.title} />
	<Features />
	<ScrollSpySteps />
	<TestimonialMasonry title={testimonialData.title} subtitle={testimonialData.subtitle} />
	<Faq subtitle={faqData.subtitle} title={faqData.title} />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
