---
// Home Page
// ------------
// Description: The home page is a page that displays the most important information.

// Components
// - Layout
import Layout from '../layouts/Layout.astro'

// - Blocks
import Hero from '../components/blocks/hero/SimpleHeroBasic.astro'
import BasicTable from '../components/blocks/pricing/BasicTable.astro'
import Brand from '../components/blocks/brand/Marquee.astro'
import Faq from '../components/blocks/faq/StickyFaq.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'

// Content
// - SEO
const SEO = {
	title: 'Blue Aurora Labs | Pricing',
	description:
		'Simple, transparent website pricing from Blue Aurora Labs. Choose the package that fits your business — no surprises, no hidden fees.'
}
// - Hero data
const heroData = {
	title: 'Straightforward pricing for every business',
	subtitle: 'Simple, Fair Pricing',
	text: "No confusing quotes, no hidden extras. Pick a package that suits your needs and we'll get started straight away."
}
// - Brand data
const brandData = {
	title: "Businesses we've worked with"
}
// - FAQ data
const faqData = {
	title: 'Everything you need to know',
	subtitle: 'Frequently Asked Questions'
}
// - CTA data
const ctaData = {
	title: 'Not sure which package is right for you?',
	text: "Every business is different. If none of our packages feel like the right fit, get in touch and we'll put together a custom proposal just for you.",
	buttonLink: '/contact',
	buttonText: 'Talk to us'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={heroData.title} subtitle={heroData.subtitle} text={heroData.text} />
	<BasicTable />
	<Brand title={brandData.title} />
	<Faq subtitle={faqData.subtitle} title={faqData.title} />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
